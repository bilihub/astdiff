<?xml version="1.0" encoding="UTF-8"?>
<configuration name="SystemConfig" version="1.0">
    <!-- Server settings -->
    <server id="main">
        <host>127.0.0.1</host>
        <port>8080</port>
        <ssl enabled="false" />
    </server>

    <!-- Logging configuration -->
    <logging>
        <level>INFO</level>
        <file>app.log</file>
    </logging>
    
    <features>
        <feature name="auth" enabled="true"/>
    </features>
</configuration>
